  "keyFeatures": [
    "100% inferred TypeScript support with end-to-end type safety",
    "Type-safe path params, search params, and navigation",
    "Built-in SWR caching for route loaders",
    "File-based and code-based routing with automatic route generation",
    "First-class search params as stateful URL state management",
    "Path and search parameter schema validation",
    "Server-side rendering (SSR) and streaming support",
    "Full-stack framework (TanStack Start) with server functions",
    "Nested layouts and pathless layout routes",
    "Automatic route prefetching and parallel data loading",
    "Route masking for URL management",
    "Multi-framework support (React, Solid, Vue)",
    "DevTools for debugging router state",
    "ESLint plugin for best practices"
  ],
  "publicApiSurface": [
    "Router - Core router instance",
    "Route - Route configuration and definitions",
    "Link - Type-safe navigation component",
    "useNavigate - Programmatic navigation hook",
    "useParams - Access path parameters",
    "useSearch - Access and update search parameters",
    "useLoaderData - Access route loader data",
    "useRouter - Access router instance",
    "useMatch - Access current route match",
    "Outlet - Render child routes",
    "createFileRoute - File-based route definition",
    "createRoute - Code-based route definition",
    "RouterProvider - Root router provider component",
    "createRouter - Create router instance",
    "redirect - Server and client redirects",
    "notFound - Throw not found errors",
    "createServerFn - Define server functions (Start)",
    "useServerFn - Use server functions (Start)",
    "StartServer - Server entry point (Start)",
    "StartClient - Client entry point (Start)"
  ]
}
